# Variables d'environnement — Backend Vercel
# À ajouter dans : Vercel Dashboard → ton projet backend → Settings → Environment Variables

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# 1. Créer un compte sur https://www.mongodb.com/atlas
# 2. Créer un cluster gratuit (M0 Free Tier)
# 3. Database Access → Add user (username + password)
# 4. Network Access → Add IP → 0.0.0.0/0 (autorise Vercel)
# 5. Connect → Drivers → copier l'URI ci-dessous
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/worldcuphub?retryWrites=true&w=majority

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Génère une chaîne aléatoire forte, ex avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=remplace_par_une_chaine_aleatoire_tres_longue

# ── URL du frontend (pour CORS) ───────────────────────────────────────────────
FRONTEND_URL=https://world-cup-hub-kappa.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement — Frontend React (fichier .env dans world-cup-hub/)
# ─────────────────────────────────────────────────────────────────────────────

# URL de ton backend Vercel Functions (sans slash final)
# Laisse vide si backend et frontend sont sur le même projet Vercel
VITE_API_URL=https://world-cup-hub-api.vercel.app
